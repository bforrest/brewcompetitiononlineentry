<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
    bootstrap="tests/bootstrap.php"
    colors="true"
    cacheDirectory=".phpunit.cache"
    executionOrder="depends,defects"
    failOnRisky="true"
    displayDetailsOnTestsThatTriggerWarnings="true"
><!--
    failOnWarning is intentionally NOT set: the legacy library triggers
    pre-existing benign PHP runtime warnings (e.g. undefined array keys in
    date_time.lib.php) that are catalogued, not test failures. Tests and
    risky tests still fail the build; warnings are surfaced but don't block.
    Re-enable failOnWarning as the warned code migrates in later phases.
-->
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
        </testsuite>
        <testsuite name="Approval">
            <directory>tests/Approval</directory>
        </testsuite>
    </testsuites>
</phpunit>
