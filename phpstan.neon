includes:
    - phpstan-baseline.neon

parameters:
    level: 0
    # Analysis of the full lib/ set peaks above the 128M default.
    tmpDir: .phpstan.cache
    paths:
        - lib

    excludePaths:
        - vendor
        - cache(?)
        - user_docs
        - user_images
        - user_temp
        - js_includes
        # (?) marks paths that may be absent (e.g. git-ignored dirs not
        # checked out in CI) so PHPStan treats them as optional.
        - Docs(?)
        - .claude(?)
        - .github(?)
