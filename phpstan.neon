includes:
    - phpstan-baseline.neon

parameters:
    level: 0
    bootstrapFiles:
        - templates/helpers.php
    # Analysis of the full lib/ set peaks above the 128M default.
    tmpDir: .phpstan.cache
    # The baseline is generated on PHP 8.5 but CI runs 8.2; version-specific
    # deprecation entries won't all fire on 8.2, so don't fail on unmatched
    # baseline patterns.
    reportUnmatchedIgnoredErrors: false
    paths:
        - lib
        - src

    excludePaths:
        - vendor
        - cache(?)
        - user_docs
        - user_images
        - user_temp
        - js_includes
        # (?) marks paths that may be absent (e.g. git-ignored dirs not
        # checked out in CI) so PHPStan treats them as optional.
        - Docs(?)
        - .claude(?)
        - .github(?)

rules:
    - Bcoem\PHPStan\NoMysqliOutsideConnectionRule
    - Bcoem\PHPStan\NoLegacyReferenceOutsideLegacyRule
